# Copy to .env.local for local development (never commit the real file).
# See docs/coding-standards.md §21 and POSCountr-UI-Planning/poscountr-ui-docker-plan.md §4.

# Base URL of the POSCountr API this build talks to, including the version prefix.
VITE_API_BASE_URL=http://localhost:8200/api/v1

# Which stage this build belongs to: local | stage | production
# Purely informational (shown in non-production builds), never used for logic branching.
VITE_APP_STAGE=local
