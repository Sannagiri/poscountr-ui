# Reference values for a production deployment. Copy to `.env` next to
# docker-compose.production.yml on the server — one per tenant deployment.
# COMPOSE_PROJECT_NAME/WEB_PORT/TENANT_SLUG are read by docker-compose.production.yml
# itself (project isolation + host port binding); VITE_* are passed through as
# build-args to docker/Dockerfile.production and get baked into the JS bundle.

# Per-tenant deployment identity.
TENANT_SLUG=la-rosetta
COMPOSE_PROJECT_NAME=poscountr_ui_la_rosetta
WEB_PORT=8201

# Baked into the build — same central API for every tenant.
VITE_API_BASE_URL=https://api.poscountr.com/api/v1
VITE_APP_STAGE=production
